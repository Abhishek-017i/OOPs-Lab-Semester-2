public class Three {
    public static void main(String[] args){
        Product p1 = new Product("MiltonUnisteel_0123","Bottle_244i983",379.5);
        p1.dispProduct();

        ElectricalProduct ep1 = new ElectricalProduct("SamsoongCharger_218e9i", "Charger_wekf2", 1212.2,"180-220",65.);
        ep1.dispEP();
        ep1.updateRange("120-150");
        ep1.updateWattage(75.);
        ep1.dispEP();
    }
}
